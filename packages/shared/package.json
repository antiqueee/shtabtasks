{
  "name": "@shtab/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "default": "./dist/schemas.js"
    },
    "./llm": {
      "types": "./dist/llm/openrouter.d.ts",
      "default": "./dist/llm/openrouter.js"
    },
    "./stt": {
      "types": "./dist/stt/yandex.d.ts",
      "default": "./dist/stt/yandex.js"
    },
    "./utils/dates": {
      "types": "./dist/utils/dates.d.ts",
      "default": "./dist/utils/dates.js"
    },
    "./utils/rrule": {
      "types": "./dist/utils/rrule.d.ts",
      "default": "./dist/utils/rrule.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "rrule": "^2.8.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
