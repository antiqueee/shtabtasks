{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@shtab/db": ["../../packages/db/src/index.ts"],
      "@shtab/shared": ["../../packages/shared/src/index.ts"],
      "@shtab/shared/llm": ["../../packages/shared/src/llm/openrouter.ts"],
      "@shtab/shared/stt": ["../../packages/shared/src/stt/yandex.ts"],
      "@shtab/shared/utils/rrule": ["../../packages/shared/src/utils/rrule.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
