NODE_ENV=production
TZ=Europe/Moscow

PUBLIC_URL=http://YOUR_SERVER_IP

APP_PORT=3000

POSTGRES_USER=shtab
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD
POSTGRES_DB=shtab
DATABASE_URL=postgresql://shtab:YOUR_STRONG_PASSWORD@postgres:5432/shtab

AUTH_SECRET=YOUR_RANDOM_SECRET_MIN_32_CHARS
AUTH_OWNER_EMAIL=owner@example.com
AUTH_OWNER_PASSWORD=YOUR_OWNER_PASSWORD

OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL_FAST=google/gemini-2.5-flash
OPENROUTER_MODEL_SMART=google/gemini-2.5-pro

YC_API_KEY=YOUR_YANDEX_CLOUD_API_KEY
YC_FOLDER_ID=YOUR_YANDEX_FOLDER_ID

TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_OWNER_ID=YOUR_TELEGRAM_USER_ID
