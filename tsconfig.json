{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true
  },
  "references": [
    { "path": "./packages/db" },
    { "path": "./packages/shared" },
    { "path": "./apps/bot" }
  ],
  "exclude": ["node_modules"]
}
